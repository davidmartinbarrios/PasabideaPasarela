        CONECTORES_DI["CONECTORES_DI<br/>PK: (no declarada)<br/>- PROCEDIMIENTO: varchar(50)<br/>- ID_CONECTOR: varchar(250)<br/>- DIAGRAMA: varchar(250)<br/>- NUM: numeric(18,0)<br/>- NUM_SEC_DESDE: numeric(18,0)<br/>- NUM_SEC_HASTA: numeric(18,0)<br/>- CAT_CONECTOR: varchar(250)<br/>- CAT_CONECTOR2: varchar(250)<br/>- DI_ID: numeric(18,0)<br/>- ORDEN_N1: numeric(18,0)<br/>- ORDEN_N2: numeric(18,0)<br/>- ORDEN_N3: numeric(18,0)<br/>- ORDEN_N4: numeric(18,0)<br/>- TIPO_CONECTOR: numeric(18,0)<br/>- SALIDA: char(1)"]:::modB
